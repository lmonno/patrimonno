generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTHENTICATION (NextAuth) ──────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── USER (solo login) ──────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  nome           String
  email          String    @unique
  hashedPassword String
  ruolo          Ruolo     @default(UTENTE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  accounts Account[]
  sessions Session[]
  intestatari          Intestatario[]
  rapporti             Rapporto[]
  flussiStraordinari   FlussoStraordinario[]

  @@map("users")
}

enum Ruolo {
  ADMIN
  UTENTE
}

// ─── DOMAIN MODELS ──────────────────────────────────────────────

model Intestatario {
  id        String    @id @default(cuid())
  nome      String
  cognome   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  conti               ContoIntestatario[]
  entrate             Entrata[]
  flussiStraordinari  FlussoStraordinario[]
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  @@map("intestatari")
}

model TipoConto {
  id        String    @id @default(cuid())
  nome      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  conti Conto[]

  @@map("tipi_conto")
}

model Rapporto {
  id         String    @id @default(cuid())
  nome       String
  istituto   String
  iban       String?
  note       String?   @db.Text
  archiviato Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  conti Conto[]
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  @@map("rapporti")
}

model Conto {
  id          String    @id @default(cuid())
  rapportoId  String
  nome        String
  tipoContoId String
  liquido     Boolean   @default(true)
  archiviato  Boolean   @default(false)
  ordine      Int       @default(0)
  note        String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  rapporto    Rapporto            @relation(fields: [rapportoId], references: [id])
  tipoConto   TipoConto           @relation(fields: [tipoContoId], references: [id])
  intestatari ContoIntestatario[]
  saldi       Saldo[]

  @@map("conti")
}

model ContoIntestatario {
  id             String @id @default(cuid())
  contoId        String
  intestatarioId String

  conto        Conto        @relation(fields: [contoId], references: [id], onDelete: Cascade)
  intestatario Intestatario @relation(fields: [intestatarioId], references: [id], onDelete: Cascade)

  @@unique([contoId, intestatarioId])
  @@map("conto_intestatari")
}

model Saldo {
  id        String   @id @default(cuid())
  contoId   String
  anno      Int
  mese      Int
  valore    Decimal  @db.Decimal(15, 2)
  formula   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conto Conto @relation(fields: [contoId], references: [id], onDelete: Cascade)

  @@unique([contoId, anno, mese])
  @@map("saldi")
}

// ─── ENTRATE ──────────────────────────────────────────────────

model TipoEntrata {
  id        String    @id @default(cuid())
  nome      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  entrate Entrata[]

  @@map("tipi_entrata")
}

model Entrata {
  id              String   @id @default(cuid())
  intestatarioId  String
  tipoEntrataId   String
  anno            Int
  mese            Int
  valore          Decimal  @db.Decimal(15, 2)
  note            String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  intestatario Intestatario @relation(fields: [intestatarioId], references: [id], onDelete: Cascade)
  tipoEntrata  TipoEntrata  @relation(fields: [tipoEntrataId], references: [id], onDelete: Cascade)

  @@unique([intestatarioId, tipoEntrataId, anno, mese])
  @@map("entrate")
}

// ─── FLUSSI STRAORDINARI ──────────────────────────────────────

model CategoriaFlusso {
  id        String    @id @default(cuid())
  nome      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  flussi FlussoStraordinario[]

  @@map("categorie_flusso")
}

model FlussoStraordinario {
  id              String   @id @default(cuid())
  data            DateTime @db.Date
  importo         Decimal  @db.Decimal(15, 2)
  descrizione     String   @db.Text
  categoriaId     String
  intestatarioId  String?
  ammortizzare    Boolean  @default(false)
  mesiAmmortamento Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categoria    CategoriaFlusso @relation(fields: [categoriaId], references: [id])
  intestatario Intestatario?   @relation(fields: [intestatarioId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  @@map("flussi_straordinari")
}
